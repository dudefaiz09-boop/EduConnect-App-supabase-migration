# Google Cloud / Vertex AI Settings
# ADC (Application Default Credentials) is used automatically in production via Service Accounts.
# For local dev, run `gcloud auth application-default login`.
PROJECT_ID="your-google-cloud-project-id"
VERTEX_LOCATION="us-central1"

# FIREBASE_API_KEY: Optional override for Firebase API key.
FIREBASE_API_KEY="MY_FIREBASE_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
