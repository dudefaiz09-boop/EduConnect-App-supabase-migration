{
  "entities": {
    "User": {
      "title": "Enhanced User Profile",
      "description": "User account with granular permissions",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "roles": { "type": "array", "items": { "type": "string" } },
        "isAdmin": { "type": "boolean" },
        "permissions": {
          "type": "object",
          "properties": {
            "manageStudents": { "type": "boolean" },
            "manageTeachers": { "type": "boolean" },
            "manageAnnouncements": { "type": "boolean" },
            "manageAttendance": { "type": "boolean" },
            "manageFees": { "type": "boolean" },
            "manageLibrary": { "type": "boolean" },
            "manageAssignments": { "type": "boolean" },
            "managePerformance": { "type": "boolean" },
            "financialOps": { "type": "boolean" }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "roles", "isAdmin"]
    },
    "Announcement": {
      "title": "Announcement",
      "description": "School-wide or class-specific announcements",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "targetRoles": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    },
    "Attendance": {
      "title": "Attendance Record",
      "description": "Daily attendance for a student",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["present", "absent", "late"] },
        "markedBy": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "date", "status", "markedBy"]
    },
    "Assignment": {
      "title": "Assignment",
      "description": "Academic assignments for students",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "subject": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "attachments": { "type": "array", "items": { "type": "string" } },
        "createdBy": { "type": "string" }
      },
      "required": ["title", "subject", "dueDate", "createdBy"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Global and targeted announcements"
    },
    "/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Student attendance logs"
    },
    "/assignments/{assignmentId}": {
      "schema": "Assignment",
      "description": "Academic tasks"
    }
  }
}
