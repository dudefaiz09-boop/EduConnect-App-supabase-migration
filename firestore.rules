rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Safety Net: Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helper Functions ---
    
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getClaims() {
      return request.auth.token;
    }

    function hasRole(role) {
      return isSignedIn() && role in getClaims().roles;
    }

    function can(permission) {
      return isSignedIn() && getClaims().permissions[permission] == true;
    }

    // USERS
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || can('manageStudents') || can('manageTeachers'));
      allow list: if can('manageStudents') || can('manageTeachers');
      
      allow update: if isSignedIn() && (
          can('financialOps') || 
          (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL']))
      );
    }

    // ANNOUNCEMENTS
    match /announcements/{announcementId} {
      allow read: if isSignedIn();
      allow create: if can('manageAnnouncements');
      allow update: if can('manageAnnouncements') && existing().authorId == request.auth.uid;
      allow delete: if can('financialOps') || (can('manageAnnouncements') && existing().authorId == request.auth.uid);
    }

    // ATTENDANCE
    match /attendance/{attendanceId} {
      allow read: if isSignedIn() && (request.auth.uid == resource.data.studentId || can('manageAttendance'));
      allow write: if can('manageAttendance');
    }

    // TEST CONNECTION
    match /test/connection {
      allow read: if true;
    }
  }
}
